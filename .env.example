# =============================================================================
# Publiciart Builder — variáveis para Docker Compose / Coolify
# Copie para `.env` antes de rodar `docker compose up --build`.
# =============================================================================

APP_NAME=Publiciart Builder
APP_URL=https://seudominio.com
NODE_ENV=production

FRONTEND_PORT=3000
BACKEND_PORT=4000

# Frontend (build-time)
VITE_APP_NAME=Publiciart Builder
VITE_APP_URL=https://seudominio.com
VITE_API_BASE_URL=https://api.seudominio.com

# Banco de dados
POSTGRES_USER=publiciart
POSTGRES_PASSWORD=troque-essa-senha
POSTGRES_DB=publiciart
DATABASE_URL=postgresql://publiciart:troque-essa-senha@postgres:5432/publiciart

# Auth
JWT_SECRET=troque-essa-chave-com-mais-de-32-caracteres
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# SMTP (deixe vazio em dev — link de reset é logado no console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Publiciart Builder

# Provedor de IA (mock = geração local determinística)
AI_PROVIDER=mock
AI_API_KEY=
AI_API_URL=

# Storage (S3 / R2 / MinIO)
STORAGE_PROVIDER=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=

# Engine de créditos (informativo — valores reais em backend/src/services/creditEngine.ts)
CREDIT_VALUE_BRL=0.10
MIN_MARGIN_MULTIPLIER=3
