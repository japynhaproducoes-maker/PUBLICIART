# Database
DATABASE_URL="postgresql://user:password@localhost:5432/publiciart"

# Auth
JWT_SECRET="troque-por-segredo-seguro-em-producao"
JWT_EXPIRES_IN="7d"
BCRYPT_ROUNDS=10

# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# IA — Google Gemini
AI_PROVIDER=gemini
AI_API_KEY=sua-chave-aqui  # console.cloud.google.com → APIs → Gemini API

# SMTP (opcional — para recuperação de senha)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@publiciart.com
SMTP_FROM_NAME=Publiciart Builder

# Storage S3 (opcional)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=
